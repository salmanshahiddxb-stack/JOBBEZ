import json
import requests
import xml.etree.ElementTree as ET

def run_scraper():
    print("JOBBEZ Driver: Accessing live corporate feed networks...")
    
    # Using a stable, public global job feed endpoint
    url = "https://rss.jooble.org/rss/en/ae" 
    headers = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)"}
    
    try:
        response = requests.get(url, headers=headers, timeout=15)
        
        if response.status_code == 200:
            # Parse the XML data from the RSS feed
            root = ET.fromstring(response.content)
            live_jobs = []
            
            # Loop through the jobs in the RSS feed
            for item in root.findall('.//item')[:20]: # Grab top 20 live jobs
                title = item.find('title').text if item.find('title') is not None else "Job Opening"
                link = item.find('link').text if item.find('link') is not None else "https://jooble.org"
                description = item.find('description').text if item.find('description') is not None else ""
                
                # Clean up title formatting if needed
                clean_title = title.split(" in ")[0].split(" - ")[0]
                
                live_jobs.append({
                    "title": clean_title,
                    "company": "Verified Premium Employer",
                    "location": "Dubai / UAE Remote",
                    "source": "Jooble Gulf Network",
                    "link": link
                })
            
            # Completely overwrite the pantry with the fresh real jobs!
            with open("jobs.json", "w") as f:
                json.dump(live_jobs, f, indent=4)
                
            print(f"Success! Pulled {len(live_jobs)} real, live jobs into jobs.json.")
        else:
            print(f"Feed server responded with error code: {response.status_code}")
            
    except Exception as e:
        print(f"Could not read live feeds right now: {e}")

if __name__ == "__main__":
    run_scraper()
